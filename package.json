{
    "name": "diagramador-arquitectura-3d",
    "displayName": "Diagramador de Arquitectura 3D",
    "description": "Editor de diagramas 3D isométricos para arquitectura de software",
    "version": "1.4.4",
    "icon": "resources/logo.png",
    "publisher": "kibotech",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/kiboki1234/extensionDiagramas3D.git"
    },
    "license": "MIT",
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "aether.openDiagramEditor",
                "title": "Aether: Abrir Diagramador 3D",
                "icon": "$(edit)"
            },
            {
                "command": "aether.scanArchitecture",
                "title": "Aether: Escanear Arquitectura del Proyecto",
                "icon": "$(search)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "aether-diagram",
                    "title": "Diagramador 3D",
                    "icon": "resources/logo.svg"
                }
            ]
        },
        "views": {
            "aether-diagram": [
                {
                    "id": "aether-diagram.menu",
                    "name": "Menú",
                    "type": "tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "aether.openDiagramEditor",
                    "when": "view == aether-diagram.menu",
                    "group": "navigation"
                },
                {
                    "command": "aether.scanArchitecture",
                    "when": "view == aether-diagram.menu",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
        "esbuild-watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
        "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/uuid": "^10.0.0",
        "@types/vscode": "^1.90.0",
        "esbuild": "^0.23.0",
        "typescript": "^5.5.0"
    },
    "dependencies": {
        "uuid": "^13.0.0"
    }
}